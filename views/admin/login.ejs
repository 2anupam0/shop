<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login | ANUP CAKE SHOP</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-login-page">
  <div class="login-box">
    <h1 style="font-family:'Playfair Display',serif;font-weight:800;letter-spacing:1px;">ANUP</h1>
    <p style="text-align:center;color:var(--gold-400);font-weight:600;font-size:0.9rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:4px;">Cake Shop</p>
    <div class="divider" style="justify-content:center;margin:8px 0 16px;"><span class="divider-line"></span><span class="divider-icon">✦</span><span class="divider-line"></span></div>
    <p style="text-align:center;color:var(--brown-400);margin-bottom:28px;font-size:0.88rem;">Admin Dashboard</p>
    <% if (error) { %>
    <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required placeholder="admin">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="********">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%">Sign In</button>
    </form>
    <p style="text-align:center;margin-top:20px;font-size:0.85rem;color:var(--brown-300);">
      <a href="/" style="color:var(--brown-500);font-weight:600;">← Back to website</a>
    </p>
  </div>
</body>
</html>
