<%- include('partials/header', { path: '/contact', title: 'Contact Us' }) %>

<section class="contact-section">
  <div class="container">
    <div class="section-decoration">✦ ✦ ✦</div>
    <h2 class="section-title reveal">Get in <span class="highlight">Touch</span></h2>
    <p class="section-subtitle reveal reveal-delay-1">We'd love to hear from you! Reach out for orders, inquiries, or custom cake requests.</p>

    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-item reveal reveal-delay-1">
          <div class="icon">📍</div>
          <div>
            <h4>Location</h4>
            <p>Bharatpur-6 Chowk Bazar, Nepal</p>
          </div>
        </div>

        <div class="contact-item reveal reveal-delay-2">
          <div class="icon">⏰</div>
          <div>
            <h4>Hours</h4>
            <p>Sun - Sat: 7:00 AM - 9:00 PM</p>
          </div>
        </div>

        <div class="contact-social-wrap">
          <a href="https://facebook.com" target="_blank" class="contact-social-link" style="background:#1877F2;">
            <span style="font-size:1.3rem;">f</span>
            <span>Facebook</span>
          </a>
          <a href="https://wa.me/9779763624678" target="_blank" class="contact-social-link" style="background:#25D366;">
            <span style="font-size:1.3rem;">📱</span>
            <span>WhatsApp</span>
          </a>
          <a href="https://instagram.com" target="_blank" class="contact-social-link" style="background:#E1306C;">
            <span style="font-size:1.3rem;">◻</span>
            <span>Instagram</span>
          </a>
        </div>

        <div class="contact-offer-card reveal reveal-delay-2">
          <h4>Order & Save</h4>
          <p>Get <strong>15% off</strong> on all cakes. Order now!</p>
          <div class="contact-offer-actions">
            <button class="btn-offer-secondary" onclick="openOrderModal()">📱 Order Online</button>
            <a href="https://wa.me/9779763624678?text=Hi%20ANUP%20Cake%20Shop!" target="_blank" class="btn-offer-secondary">📱 WhatsApp Us</a>
          </div>
        </div>
      </div>

      <div class="contact-form reveal reveal-delay-3">
        <h3 class="contact-form-title">Send a Message</h3>
        <form id="contactForm">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" required placeholder="Enter your name">
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" required placeholder="98XXXXXXXX">
          </div>
          <div class="form-group">
            <label for="cake">Cake Interest</label>
            <select id="cake" name="cake">
              <option value="">Select a cake type</option>
              <option>Chocolate</option>
              <option>Vanilla</option>
              <option>Custom Cake</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" required placeholder="Tell us about your order..."></textarea>
          </div>
          <button type="submit" class="btn-contact-submit">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
