<%- include('partials/header', { path: '/contact', title: 'Contact Us' }) %>

<section class="contact-section">
  <div class="container">
    <div class="section-decoration">✦ ✦ ✦</div>
    <h2 class="section-title reveal">Get in <span class="highlight">Touch</span></h2>
    <p class="section-subtitle reveal reveal-delay-1">We'd love to hear from you! Reach out for orders, inquiries, or custom cake requests.</p>

    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-item reveal reveal-delay-1">
          <div class="icon">📍</div>
          <div>
            <h4>Location</h4>
            <p>Bharatpur-6 Chowk Bazar, Nepal</p>
          </div>
        </div>

        <div class="contact-item reveal reveal-delay-2">
          <div class="icon">📞</div>
          <div>
            <h4>Phone</h4>
            <p><a href="tel:+9779865253798" style="color:var(--brown-500);font-weight:600;">9865253798</a></p>
          </div>
        </div>

        <div class="contact-item reveal reveal-delay-3">
          <div class="icon">⏰</div>
          <div>
            <h4>Hours</h4>
            <p>Sun - Sat: 7:00 AM - 9:00 PM</p>
          </div>
        </div>

        <div class="contact-item reveal reveal-delay-1">
          <div class="icon">📱</div>
          <div>
            <h4>WhatsApp</h4>
            <p><a href="https://wa.me/9779865253798" target="_blank" style="color:#25D366;font-weight:600;">Chat with us</a></p>
          </div>
        </div>

        <div class="reveal reveal-delay-2" style="margin-top:32px;padding:28px;background:linear-gradient(135deg,var(--cream-200),var(--brown-50));border-radius:16px;border:1px solid var(--brown-100);">
          <h4 style="margin-bottom:8px;color:var(--brown-700);font-size:1.15rem;font-family:'Playfair Display',serif;">Order & Save</h4>
          <p style="color:var(--brown-400);font-size:0.95rem;">Get <strong style="color:var(--brown-500);">50g free</strong> on every 1 pound cake. Order now!</p>
          <div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap;">
            <button class="btn btn-gold" onclick="openOrderModal()">Order Online</button>
            <a href="https://wa.me/9779865253798?text=Hi%20Jivan%20Cake%20Shop!" target="_blank" class="btn btn-whatsapp">WhatsApp Us</a>
          </div>
        </div>
      </div>

      <div class="contact-form reveal reveal-delay-3">
        <h3 style="font-family:'Playfair Display',serif;font-size:1.3rem;margin-bottom:20px;color:var(--brown-700);">Send a Message</h3>
        <form id="contactForm">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" required placeholder="Enter your name">
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" required placeholder="98XXXXXXXX">
          </div>
          <div class="form-group">
            <label for="cake">Cake Interest</label>
            <select id="cake" name="cake">
              <option value="">Select a cake type</option>
              <option>Chocolate</option>
              <option>Vanilla</option>
              <option>Custom Cake</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" required placeholder="Tell us about your order..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
