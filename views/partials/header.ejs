<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.title ? locals.title + ' | ANUP CAKE SHOP' : 'ANUP CAKE SHOP' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <div class="container">
    <a href="/" class="logo">
      <img src="/images/logo.png" alt="ANUP CAKE SHOP" class="logo-img">
    </a>
    <button class="menu-toggle">☰</button>
    <nav>
      <a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a>
      <a href="/menu" class="<%= path === '/menu' ? 'active' : '' %>">Menu</a>
      <a href="/contact" class="<%= path === '/contact' ? 'active' : '' %>">Contact</a>
    </nav>
  </div>
</header>
